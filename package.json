{
  "name": "@mdit/root",
  "private": true,
  "description": "MarkdownIt plugin collections written in typescript",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production pnpm run --stream -r build",
    "bundle:analyze": "node --experimental-strip-types scripts/analyze.ts",
    "clean": "pnpm run --stream -r clean",
    "docs:build": "pnpm run --filter=docs docs:build",
    "docs:dev": "pnpm run --filter=docs docs:dev",
    "lint": "oxlint --fix --type-aware --type-check --report-unused-disable-directives --deny-warnings && oxfmt",
    "lint:check": "oxlint --type-aware --type-check --report-unused-disable-directives --deny-warnings && oxfmt --check",
    "lint:md": "markdownlint-cli2 **/*.md",
    "packages:bootstrap": "node --experimental-strip-types scripts/bootstrap.ts",
    "packages:check-update": "pnpm dlx npm-check-updates -u --deep --timeout 600000",
    "packages:update": "pnpm up -r",
    "prepare": "husky",
    "release": "pnpm run clean && pnpm run build && pnpm run release:version && pnpm run release:publish && pnpm run release:sync",
    "release:publish": "lerna publish from-package --yes",
    "release:sync": "node --experimental-strip-types scripts/sync.ts",
    "release:version": "lerna version",
    "test": "vitest run",
    "test:bench": "vitest bench --run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@codecov/bundle-analyzer": "1.9.1",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@lerna-lite/cli": "5.0.0",
    "@lerna-lite/publish": "5.0.0",
    "@mr-hope/tsconfig": "0.0.3",
    "@types/node": "25.5.2",
    "@vitest/coverage-istanbul": "4.1.2",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cross-env": "10.1.0",
    "husky": "9.1.7",
    "markdownlint-cli2": "0.22.0",
    "nano-staged": "0.9.0",
    "npm-check-updates": "20.0.0",
    "oxc-config-hope": "0.1.6",
    "oxfmt": "0.43.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.19.0",
    "publint": "0.3.18",
    "rimraf": "6.1.3",
    "tsdown": "0.21.7",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --type-check --type-aware --report-unused-disable-directives",
    "*.md": "markdownlint-cli2 --fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "packageManager": "pnpm@10.33.0"
}
