{
  "name": "@mdit/plugin-include",
  "version": "0.23.2",
  "description": "include plugin for MarkdownIt",
  "keywords": [
    "include",
    "markdown-it",
    "markdown-it-plugin"
  ],
  "homepage": "https://mdit-plugins.github.io/include.html",
  "bugs": {
    "url": "https://github.com/mdit-plugins/mdit-plugins/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdit-plugins/mdit-plugins.git",
    "directory": "packages/include"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf ./dist"
  },
  "dependencies": {
    "@mdit/helper": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "upath": "^3.0.7"
  },
  "devDependencies": {
    "@mdit/plugin-container": "workspace:*"
  },
  "peerDependencies": {
    "markdown-it": "^14.1.0"
  },
  "peerDependenciesMeta": {
    "markdown-it": {
      "optional": true
    }
  },
  "engines": {
    "node": ">= 20"
  }
}
