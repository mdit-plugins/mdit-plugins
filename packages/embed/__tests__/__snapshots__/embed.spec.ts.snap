// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`embed > block embeds > should handle unknown embed type 1`] = `
"<p>{% unknown some-param %}</p>
"
`;

exports[`embed > block embeds > should render GitHub embed 1`] = `"<div class="github-embed"><a href="https://github.com/octocat/Hello-World">github.com/octocat/Hello-World</a></div>"`;

exports[`embed > block embeds > should render Twitter embed 1`] = `"<blockquote class="twitter-tweet"><a href="https://twitter.com/user/status/12345"></a></blockquote>"`;

exports[`embed > block embeds > should render YouTube embed 1`] = `"<iframe width="560" height="315" src="https://www.youtube.com/embed/dQw4w9WgXcQ" frameborder="0" allowfullscreen></iframe>"`;

exports[`embed > inline embeds > should render inline badge embed 1`] = `
"<p>Status: <span class="badge">active</span></p>
"
`;

exports[`embed > inline embeds > should render inline icon embed 1`] = `
"<p>Click the <i class="icon icon-home"></i> button to go home.</p>
"
`;

exports[`embed > inline embeds > should render multiple inline embeds 1`] = `
"<p><i class="icon icon-star"></i> Rating: <span class="badge">5 stars</span> <i class="icon icon-thumbs-up"></i></p>
"
`;

exports[`embed > should handle unknown embed type 1`] = `
"<p>{% unknown some-param %}</p>
"
`;

exports[`embed > should render GitHub embed 1`] = `"<div class="github-embed"><a href="https://github.com/octocat/Hello-World">github.com/octocat/Hello-World</a></div>"`;

exports[`embed > should render Twitter embed 1`] = `"<blockquote class="twitter-tweet"><a href="https://twitter.com/user/status/12345"></a></blockquote>"`;

exports[`embed > should render YouTube embed 1`] = `"<iframe width="560" height="315" src="https://www.youtube.com/embed/dQw4w9WgXcQ" frameborder="0" allowfullscreen></iframe>"`;
